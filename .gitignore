# Secrets — NEVER commit
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Dependencies
**/node_modules/

# Build output
**/dist/
**/build/
**/.vite/
**/.next/
**/out/

# Caches / temp
**/.cache/
**/*.tsbuildinfo
**/.eslintcache

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# Misc
*.local
.tmp/

# Real client data — NEVER commit
# (.env.local is already matched by .env.* above; listed here as a reminder)
.env.local
backups/
**/*_export.csv
